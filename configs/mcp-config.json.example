{
  "_comment": "Claude Desktop MCP configuration — paste the 'mcpServers' block into your claude_desktop_config.json",

  "mcpServers": {
    "sre-agent": {
      "command": "/path/to/sre-mcp-server",
      "args": [],
      "env": {
        "SERVER_NAME": "sre-mcp-server",
        "SERVER_VERSION": "0.1.0",
        "LOG_LEVEL": "info",

        "OTEL_EXPORTER_OTLP_ENDPOINT": "localhost:4317",
        "OTEL_SERVICE_NAME": "sre-mcp-server",

        "THANOS_QUERY_URL": "http://thanos-query.your-cluster:9090",
        "PROMETHEUS_URL": "http://prometheus.your-cluster:9090",

        "LOKI_URL": "http://loki.your-cluster:3100",
        "TEMPO_URL": "http://tempo.your-cluster:3200",

        "ALERTMANAGER_URL": "http://alertmanager.your-cluster:9093",

        "GRAFANA_URL": "http://grafana.your-cluster:3000",
        "GRAFANA_API_TOKEN": "your-grafana-service-account-token",

        "SLACK_BOT_TOKEN": "xoxb-your-slack-bot-token",
        "SLACK_DEFAULT_CHANNEL": "#sre-agent",

        "QUERY_TIMEOUT_SECONDS": "30"
      }
    }
  }
}
